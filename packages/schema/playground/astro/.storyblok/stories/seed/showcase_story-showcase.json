            "answer": { "type": "doc", "content": [{ "type": "paragraph", "content": [{ "text": "Use the Storyblok CLI command ", "type": "text" }, { "text": "storyblok schema push", "type": "text", "marks": [{ "type": "code" }] }, { "text": " to push your TypeScript schema definitions to your Storyblok space.", "type": "text" }] }] },
