{
  "name": "@storyblok/migrations",
  "type": "module",
  "version": "0.1.7",
  "private": false,
  "description": "Migration utilities for Storyblok",
  "author": "Storyblok",
  "license": "MIT",
  "homepage": "https://github.com/storyblok/monoblok/tree/main/packages/migrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyblok/monoblok.git",
    "directory": "packages/migrations"
  },
  "bugs": {
    "url": "https://github.com/storyblok/monoblok/issues"
  },
  "keywords": [
    "storyblok",
    "migrations",
    "content",
    "cms",
    "headless",
    "schema",
    "data-migration"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "vitest dev",
    "play": "jiti playground",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "pnpm run build",
    "test": "pnpm lint && pnpm test:types && vitest run --coverage",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:types": "tsc --noEmit --skipLibCheck",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@storyblok/management-api-client": "workspace:*",
    "@storyblok/richtext": "workspace:*",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@storyblok/eslint-config": "workspace:*",
    "@types/node": "^22.15.18",
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.26.0",
    "jiti": "^2.4.2",
    "tsdown": "^0.20.3",
    "typescript": "5.8.3",
    "vitest": "^3.1.3"
  }
}
