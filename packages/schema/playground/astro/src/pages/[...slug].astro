---
import '../global.css';
import { createStoryblokClient } from '../lib/storyblok';
import StoryblokComponent from '../components/storyblok/storyblok-component.astro';

const { slug } = Astro.params;

const client = createStoryblokClient();
const result = await client.stories.get(slug ?? 'home', { query: { version: 'draft' } });
const story = result.data?.story ?? null;

if (!story) {
  return Astro.redirect('/404');
}

const content = story.content.component === 'page' ? story.content : null;
const title = content?.seo_title ?? story.name;
const description = content?.seo_description ?? '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <main>
      <StoryblokComponent block={story.content} />
    </main>
  </body>
</html>
