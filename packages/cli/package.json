{
  "name": "storyblok",
  "version": "4.17.2",
  "description": "Storyblok CLI",
  "keywords": [
    "cli",
    "javascript",
    "node",
    "storyblok"
  ],
  "license": "MIT",
  "author": "Alvaro Saburido <hola@alvarosaburido.dev> (https://github.com/alvarosabu/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/storyblok/monoblok.git",
    "branch": "main",
    "directory": "packages/cli"
  },
  "bin": {
    "storyblok": "./dist/index.mjs"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config/index.d.mts",
      "import": "./dist/config/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "start": "pnpm run build && node dist/index.mjs",
    "debug": "node --inspect-brk --loader tsx src/index.ts",
    "release": "release-it",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:coverage": "vp test run --coverage"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "@storyblok/js": "workspace:*",
    "@storyblok/management-api-client": "workspace:*",
    "@storyblok/region-helper": "workspace:*",
    "@topcli/spinner": "^2.1.2",
    "async-sema": "^3.1.1",
    "c12": "^3.3.0",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "filenamify": "^6.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "minimatch": "^10.0.3",
    "octokit": "^5.0.3",
    "ohash": "^2.0.11",
    "open": "^10.1.2",
    "pathe": "^2.0.3",
    "read-package-up": "^11.0.0",
    "storyblok-js-client": "workspace:*"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "10.0.0",
    "@storyblok/lint-config": "workspace:*",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.8",
    "@types/node": "^24.11.0",
    "@vitest/coverage-v8": "^3.1.3",
    "@vitest/ui": "^3.1.3",
    "memfs": "^4.17.1",
    "msw": "^2.8.2",
    "oxlint": "^1.62.0",
    "release-it": "^18.1.2",
    "typescript": "5.8.3",
    "uuid": "^11.1.0",
    "vitest": "^3.1.3"
  }
}
