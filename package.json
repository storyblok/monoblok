{
  "name": "monoblok",
  "version": "0.1.0",
  "private": true,
  "description": "Official monorepo for Storyblok open source packages",
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "monoblok": "node tools/monoblok/dist/index.mjs",
    "prepare": "husky",
    "release": "node tools/release.mjs",
    "lint": "vp lint && nx run-many --target=lint",
    "lint:fix": "vp lint --fix && nx run-many --target=lint --fix",
    "lint:affected": "nx affected:lint",
    "format": "vp fmt && nx run-many --target=format",
    "format:check": "vp fmt --check && nx run-many --target=format:check",
    "test": "nx run-many --target=test",
    "test:types": "nx run-many --target=test:types",
    "test:coverage": "nx run-many --target=test:coverage"
  },
  "dependencies": {
    "cypress": "^14.3.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nx/js": "21.3.11",
    "@storyblok/lint-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nx": "21.3.11",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "5.8.3",
    "vite-plus": "0.1.20"
  },
  "resolutions": {
    "cypress": "^14.3.3"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "happy-dom": "^20.8.8"
    }
  }
}
