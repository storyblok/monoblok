{
  "name": "@storyblok/management-api-client",
  "version": "0.2.4",
  "private": false,
  "description": "Storyblok Management API Client",
  "keywords": [],
  "homepage": "https://github.com/storyblok/monoblok/tree/main/packages/mapi-client#readme",
  "bugs": {
    "url": "https://github.com/storyblok/monoblok/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/storyblok/monoblok.git",
    "directory": "packages/mapi-client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:coverage": "vp test run --coverage"
  },
  "dependencies": {
    "@storyblok/region-helper": "workspace:*",
    "ky": "^1.14.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.92.3",
    "@msw/source": "^0.6.1",
    "@storyblok/lint-config": "workspace:*",
    "@storyblok/openapi": "workspace:*",
    "@types/node": "^24.1.0",
    "glob": "^13.0.6",
    "msw": "^2.12.9",
    "oxlint": "^1.62.0",
    "pathe": "^2.0.3",
    "tsx": "^4.20.3",
    "vitest": "^3.1.3"
  },
  "nx": {
    "targets": {
      "generate": {
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "{projectRoot}/src/generated/**"
        ]
      },
      "build": {
        "dependsOn": [
          "generate",
          "^build"
        ],
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      }
    }
  }
}
