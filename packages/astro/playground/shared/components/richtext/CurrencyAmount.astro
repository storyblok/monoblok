---
// This component should receive the currency amount and format it
// In NordVPN's use case, they want to pass { amount: node.text }

interface Props {
  amount: string;
  data?: {
    currencySymbol: string;
    locale: string;
    headingPrefix: string;
  };
}

const { amount, data } = Astro.props;

// Format as currency (simple example)
const formatted = new Intl.NumberFormat(data?.locale || 'en-US', {
  style: 'currency',
  currency: 'USD',
}).format(parseFloat(amount) || 0);
---

<span class="currency-amount" data-original={amount}>
  {data?.currencySymbol}{formatted}
</span>

<style>
  .currency-amount {
    font-weight: bold;
    color: green;
  }
</style>
