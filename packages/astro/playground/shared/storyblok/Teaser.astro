---
import { storyblokEditable } from '@storyblok/astro';
import { segmentStoryblokRichTextDynamic } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import TestLink from '@shared/components/TestLink.astro';

const { blok } = Astro.props;

const richTextSegments = segmentStoryblokRichTextDynamic(blok.text, {
  supportedSegments: ['link'] as const,
});
---

<div {...storyblokEditable(blok)}>
  <h2 class="heading">
    {blok.headline}
  </h2>
  <pre>{JSON.stringify(richTextSegments, null, 2)}</pre>
  {
    richTextSegments.map((segment) => {
      if (segment.type === 'html') {
        return <Fragment set:html={segment.content} />;
      }
      if (segment.type === 'link') {
        return <TestLink {...segment.props} />;
      }
      if (segment.type === 'blok') {
        return <StoryblokComponent blok={segment.props} />;
      }
    })
  }
</div>
