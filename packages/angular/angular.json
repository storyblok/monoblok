{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "analytics": false
  },
  "newProjectRoot": "playground",
  "projects": {
    "@storyblok/angular": {
      "projectType": "library",
      "root": ".",
      "sourceRoot": "src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "include": ["src/**/*.spec.ts"],
            "exclude": ["playground/**"]
          }
        }
      }
    },
    "ssr-playground": {
      "projectType": "application",
      "schematics": {},
      "root": "playground/ssr",
      "sourceRoot": "playground/ssr/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "playground/ssr/src/main.ts",
            "tsConfig": "playground/ssr/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "playground/ssr/public"
              }
            ],
            "styles": ["playground/ssr/src/styles.css"],
            "server": "playground/ssr/src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "playground/ssr/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ssr-playground:build:production"
            },
            "development": {
              "buildTarget": "ssr-playground:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "app-playground": {
      "projectType": "application",
      "schematics": {},
      "root": "playground/app",
      "sourceRoot": "playground/app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "playground/app/src/main.ts",
            "tsConfig": "playground/app/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "playground/app/public"
              }
            ],
            "styles": ["playground/app/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "app-playground:build:production"
            },
            "development": {
              "buildTarget": "app-playground:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
