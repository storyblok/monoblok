# Management API (MAPI) personal access token (https://app.storyblok.com/#/me/account?tab=token)
STORYBLOK_TOKEN=

# Content API (CAPI) preview token — for fetching draft content during development
STORYBLOK_PREVIEW_TOKEN=

# Content API (CAPI) public token — for fetching published content in production
STORYBLOK_PUBLIC_TOKEN=

# Numeric ID of the target space
STORYBLOK_SPACE_ID=

# Path to the WordPress JSON dump produced by export-json.php (default: ../wordpress/data/latest)
WP_DUMP_DIR=../wordpress/data/latest
