{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultProject": "main",
  "parallel": 5,
  "namedInputs": {
    "openapiCodegen": [
      "{workspaceRoot}/tools/openapi-codegen/spec.lock",
      "{workspaceRoot}/tools/openapi-codegen/src/**",
      "{workspaceRoot}/tools/openapi-codegen/specs/**",
      "{workspaceRoot}/tools/openapi-codegen/templates/**"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:types": {
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false
    }
  },
  "tui": {
    "enabled": false
  },
  "release": {
    "projectsRelationship": "independent",
    "projects": ["packages/*"],
    "releaseTagPatternCheckAllBranchesWhen": ["alpha", "beta", "next"],
    "version": {
      "conventionalCommits": true,
      "updateDependents": "never",
      "fallbackCurrentVersionResolver": "disk",
      "versionActionsOptions": {
        "skipLockFileUpdate": true
      }
    },
    "changelog": {
      "automaticFromRef": false,
      "projectChangelogs": {
        "createRelease": "github",
        "file": false
      }
    }
  }
}
