---
import Layout from '../layouts/Layout.astro';
import { useStoryblokApi } from '@storyblok/astro';
import { formateRichText } from '@storyblok/richtext';
import AstroRichtext from '../components/AstroRichtext.astro';
import Wrapper from '../components/Wrapper';
const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get('cdn/stories/home', {
  version: 'draft',
});

const segments = formateRichText(data.story.content.richtext, {
  optimizeImages: true,
});
---

<Layout>
  <div class="flex">
    <pre>{JSON.stringify({ segments }, null, 2)}</pre>
    <AstroRichtext segments={segments} />
    <div class="react">
      <Wrapper segments={segments} />
    </div>
  </div>
</Layout>
<style>
  .flex {
    display: flex;
    gap: 20px;
  }
  pre {
    background: #f0f0f0;
    padding: 10px;
    border-radius: 5px;
    width: 100%;
    overflow-x: auto;
  }
</style>
