---
// Custom heading component that adds anchor links
import type { SbRichTextProps, SbAstroRichTextRenderContext } from '@storyblok/astro';
import Heading from '../Heading.astro';

interface CustomData {
  headingPrefix?: string;
  currencySymbol?: string;
  locale?: string;
}

type Props = SbRichTextProps<'heading'> & { context?: SbAstroRichTextRenderContext<CustomData> };

const { attrs, content, context } = Astro.props;
const level = attrs?.level || 1;

// Access custom data passed via the data prop
const customData = context?.data;
const prefix = customData?.headingPrefix;

// Try to extract text from content for ID generation
function extractText(nodes: any[]): string {
  if (!nodes) return '';
  return nodes
    .map((node) => {
      if (node.type === 'text') return node.text || '';
      if (node.content) return extractText(node.content);
      return '';
    })
    .join('');
}

const text = extractText(content || []);
const id = text
  .toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/[^a-z0-9-]/g, '');
---

<Heading level={level} id={id}>
  {prefix && <span class="heading-prefix">{prefix} </span>}
  <slot />
</Heading>

<style>
  .heading-prefix {
    color: #666;
    font-size: 0.8em;
  }
</style>
