{
  "name": "@storyblok/live-preview",
  "version": "0.1.2",
  "private": false,
  "description": "Official Live Preview integration for the Storyblok Headless CMS",
  "keywords": [
    "live-preview",
    "storyblok"
  ],
  "homepage": "https://github.com/storyblok/monoblok/tree/main/packages/live-preview#readme",
  "bugs": {
    "url": "https://github.com/storyblok/monoblok/issues"
  },
  "license": "MIT",
  "author": "Storyblok",
  "repository": {
    "type": "git",
    "url": "https://github.com/storyblok/monoblok.git",
    "directory": "packages/live-preview"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepublishOnly": "pnpm run build",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:coverage": "vp test run --coverage"
  },
  "dependencies": {
    "@storyblok/preview-bridge": "^2.1.6"
  },
  "devDependencies": {
    "@storyblok/lint-config": "workspace:*",
    "@types/node": "^24.11.0",
    "bumpp": "^10.4.1",
    "jsdom": "^25.0.0",
    "oxlint": "^1.62.0",
    "storyblok-js-client": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
