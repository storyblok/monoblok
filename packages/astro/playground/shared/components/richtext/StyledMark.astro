---
// Custom styled mark component
// This receives the mark attrs and context.data for custom props
import type { SbRichTextProps, SbAstroRichTextRenderContext } from '@storyblok/astro';
import CurrencyAmount from './CurrencyAmount.astro';

interface CustomData {
  headingPrefix?: string;
  currencySymbol?: string;
  locale?: string;
}

type Props = SbRichTextProps<'styled'> & { context?: SbAstroRichTextRenderContext<CustomData> };

const { attrs, context } = Astro.props;
const isCurrency = attrs?.class === 'currency';

// Access custom data passed via the data prop
const customData = context?.data;
const currencySymbol = customData?.currencySymbol || '$';
---

{isCurrency ? (
  <span class="currency-wrapper">
    <span class="currency-symbol">{currencySymbol}</span>
    <slot />
  </span>
) : (
  <span class={attrs?.class}>
    <slot />
  </span>
)}

<style>
  .currency-wrapper {
    font-weight: bold;
    color: #2e7d32;
  }
  .currency-symbol {
    margin-right: 0.1em;
  }
</style>
