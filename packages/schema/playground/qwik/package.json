{
  "name": "@storyblok/playground-schema-qwik",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "qwik": "qwik",
    "build": "vite build && vite build --ssr src/entry.node.tsx --outDir server",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.types": "tsc --incremental --noEmit",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "preview": "qwik build preview && vite preview --open",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "push:schema": "tsx src/schema/push.ts",
    "push:seeds": "tsx src/seeds/push.ts",
    "seed": "pnpm push:schema && pnpm push:seeds",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fastify/middie": "^9.3.1",
    "@storyblok/api-client": "workspace:*",
    "@storyblok/schema": "workspace:*",
    "fastify": "^5.8.4",
    "marked": "17.0.5"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@playwright/test": "^1.59.0",
    "@storyblok/eslint-config": "workspace:*",
    "@storyblok/management-api-client": "workspace:*",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "20.19.0",
    "dotenv": "^17.3.1",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "tailwindcss": "^4.2.2",
    "testcontainers": "^11.13.0",
    "tsx": "^4.21.0",
    "typescript": "5.4.5",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1"
  }
}
