{
  "name": "@storyblok/live-preview",
  "type": "module",
  "version": "0.4.0-alpha.1",
  "private": false,
  "description": "Official Live Preview integration for the Storyblok Headless CMS",
  "author": "Storyblok",
  "license": "MIT",
  "homepage": "https://github.com/storyblok/monoblok/tree/main/packages/live-preview#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/storyblok/monoblok.git",
    "directory": "packages/live-preview"
  },
  "bugs": {
    "url": "https://github.com/storyblok/monoblok/issues"
  },
  "keywords": [
    "live-preview",
    "storyblok"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "generate": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/generate.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "nx": {
    "targets": {
      "generate": {
        "inputs": [
          "{projectRoot}/scripts/generate.ts",
          "openapiCodegen"
        ],
        "outputs": [
          "{projectRoot}/src/generated"
        ],
        "cache": true,
        "dependsOn": [
          "@storyblok/openapi-codegen:build"
        ]
      }
    }
  },
  "dependencies": {
    "@storyblok/preview-bridge": "^2.1.6"
  },
  "devDependencies": {
    "@storyblok/eslint-config": "workspace:*",
    "@storyblok/openapi-codegen": "workspace:*",
    "@types/node": "^24.11.0",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
