              "type": "bullet_list",
              "content": [
                { "type": "list_item", "content": [{ "type": "paragraph", "content": [{ "text": "Full type safety from schema to frontend", "type": "text" }] }] },
                { "type": "list_item", "content": [{ "type": "paragraph", "content": [{ "text": "No runtime surprises — catch errors at build time", "type": "text" }] }] },
                { "type": "list_item", "content": [{ "type": "paragraph", "content": [{ "text": "Version-controlled content model alongside your code", "type": "text" }] }] }
              ]
            }
          ]
