---
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  reverse?: boolean;
}

const { title, description, image, imageAlt = '', reverse = false } = Astro.props;
---

<section>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:items-center md:gap-8">
      <div class:list={[{ 'md:order-last': reverse }]}>
        <div class="max-w-prose md:max-w-none">
          <h2 class="text-2xl font-semibold text-gray-900 sm:text-3xl">
            {title}
          </h2>

          {description && (
            <p class="mt-4 text-pretty text-gray-700">{description}</p>
          )}

          <slot />
        </div>
      </div>

      {image && (
        <div>
          <img src={image} alt={imageAlt} class="rounded" loading="lazy" decoding="async" />
        </div>
      )}
    </div>
  </div>
</section>
