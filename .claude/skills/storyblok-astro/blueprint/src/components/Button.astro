---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
}

const { href = '#', variant = 'primary' } = Astro.props;

const classes: Record<string, string> = {
  primary:
    'inline-block rounded border border-indigo-600 bg-indigo-600 px-5 py-3 font-medium text-white shadow-sm transition-colors hover:bg-indigo-700',
  secondary:
    'inline-block rounded border border-gray-200 px-5 py-3 font-medium text-gray-700 shadow-sm transition-colors hover:bg-gray-50 hover:text-gray-900',
};
---

<a href={href} class={classes[variant]}>
  <slot />
</a>
