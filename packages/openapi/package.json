{
  "name": "@storyblok/openapi",
  "version": "2.0.0",
  "description": "Storyblok Management API OpenAPI specifications",
  "private": true,
  "scripts": {
    "docs:preview": "redocly preview",
    "docs:validate": "npx @redocly/cli lint --config redocly.yaml",
    "docs:validate:fix": "npx @redocly/cli lint --config redocly.yaml --fix",
    "specs:validate": "npx @redocly/cli lint resources/**/*.yaml",
    "build": "redocly bundle"
  },
  "main": "dist",
  "keywords": [
    "openapi",
    "storyblok",
    "api",
    "documentation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@redocly/cli": "^2.0.2",
    "js-yaml": "^4.1.0"
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "inputs": [
          "{projectRoot}/resources/**",
          "{projectRoot}/redocly.yaml"
        ],
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      }
    }
  }
}
