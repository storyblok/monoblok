{
  "name": "@storyblok/angular",
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "command": "pnpm build",
      "options": {
        "cwd": "packages/angular"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "packages/angular/dist"
      }
    }
  },
  "implicitDependencies": [
    "live-preview",
    "richtext",
    "js",
    "api-client"
  ]
}
