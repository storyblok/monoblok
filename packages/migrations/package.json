{
  "name": "@storyblok/migrations",
  "version": "0.1.7",
  "private": false,
  "description": "Migration utilities for Storyblok",
  "keywords": [
    "cms",
    "content",
    "data-migration",
    "headless",
    "migrations",
    "schema",
    "storyblok"
  ],
  "homepage": "https://github.com/storyblok/monoblok/tree/main/packages/migrations#readme",
  "bugs": {
    "url": "https://github.com/storyblok/monoblok/issues"
  },
  "license": "MIT",
  "author": "Storyblok",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyblok/monoblok.git",
    "directory": "packages/migrations"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "play": "jiti playground",
    "prepack": "pnpm run build",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:coverage": "vp test run --coverage"
  },
  "dependencies": {
    "@storyblok/management-api-client": "workspace:*",
    "@storyblok/richtext": "workspace:*",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@storyblok/lint-config": "workspace:*",
    "@types/node": "^22.15.18",
    "@vitest/coverage-v8": "^3.1.3",
    "jiti": "^2.4.2",
    "oxlint": "^1.62.0",
    "typescript": "5.8.3",
    "vitest": "^3.1.3"
  }
}
