            "answer": { "type": "doc", "content": [{ "type": "paragraph", "content": [{ "text": "It is a TypeScript-first library for defining Storyblok component schemas in code. It provides ", "type": "text" }, { "text": "full type safety", "type": "text", "marks": [{ "type": "bold" }] }, { "text": " from schema definition to content delivery.", "type": "text" }] }] },
