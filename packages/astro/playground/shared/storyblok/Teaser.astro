---
import { storyblokEditable } from '@storyblok/astro';
import Heading from '../components/richtext/Heading.astro';
import Bold from '../components/richtext/Bold.astro';
import StoryblokRichText from '@storyblok/astro/StoryblokRichText.astro';

const { blok } = Astro.props;
---

<div {...storyblokEditable(blok)}>
  <h2 class="heading">
    {blok.headline}
  </h2>
  <StoryblokRichText document={blok?.text} components={{ heading: Heading, bold: Bold }} />
</div>
<style>
  .heading {
    text-align: center;
    font: 700 2.25rem/2.5rem sans-serif;
    color: var(--color-primary);
    padding: 3rem 0;
  }
</style>
