              "content": [{ "text": "Why code-driven?", "type": "text" }]
            },
            {
              "type": "paragraph",
              "content": [
                { "text": "Defining your content model in ", "type": "text" },
                { "text": "TypeScript", "type": "text", "marks": [{ "type": "bold" }] },
                { "text": " means your schema and application code stay perfectly in sync. Rename a field and the compiler tells you every place that needs updating.", "type": "text" }
