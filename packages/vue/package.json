{
  "name": "@storyblok/vue",
  "version": "10.1.4",
  "description": "SDK to integrate Storyblok into your project using Vue.",
  "homepage": "https://github.com/storyblok/monoblok/tree/main/packages/vue#readme",
  "bugs": {
    "url": "https://github.com/storyblok/monoblok/issues"
  },
  "license": "MIT",
  "author": "Storyblok",
  "repository": {
    "type": "git",
    "url": "https://github.com/storyblok/monoblok.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/storyblok-vue.js",
  "module": "./dist/storyblok-vue.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/storyblok-vue.mjs",
      "require": "./dist/storyblok-vue.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp build",
    "dev": "vp build --watch",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vp test run",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "test:e2e": "pnpm run cy:components",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test:coverage": "vp test run --coverage",
    "playground": "pnpm run --filter ./playground/vue dev",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:components": "cypress run --component"
  },
  "dependencies": {
    "@storyblok/js": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "@storyblok/lint-config": "workspace:*",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "cypress": "^14.3.3",
    "kolorist": "^1.8.0",
    "oxlint": "^1.62.0",
    "pathe": "^2.0.3",
    "typescript": "5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-banner": "^0.8.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.1.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "vue": ">=3.4"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "nx": {
    "implicitDependencies": [
      "!@storyblok/playground-*"
    ]
  }
}
